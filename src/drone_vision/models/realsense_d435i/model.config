<?xml version="1.0"?>
<model>
  <name>realsense_d435i</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Intel RealSense D435i. Dimensions, mass, stereo baseline, depth/color
    offsets and IMU placement taken from Intel's realsense2_description URDF.
    Depth and color have separate optical centres (15 mm apart), as on the real
    device, so fused code must align them.
  </description>
</model>
