<model>
  <name>gate_ring</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>Racing gate ring (torus of 16 cylinder segments), hole axis = local +X. Clear opening radius 0.371 m = iris_with_d435i cross-flight radius (0.321 m, prop tips) + 5 cm clearance. Include with a Z-yaw to aim the hole along the flight path.</description>
</model>
